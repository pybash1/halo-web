---
import "../styles/global.css";
import "@fontsource/instrument-serif";
import "@fontsource-variable/dm-sans";
import WaitlistButton from "../components/WaitlistButton";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ScrollVideoBackground from "../components/ScrollVideoBackground";
import CustomCursor from "../components/CustomCursor";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Halo - Because you're safety matters</title>
  </head>
  <body id="top" class="has-custom-cursor font-sans bg-black text-white">
    <ScrollVideoBackground client:load />
    <CustomCursor client:load />

    <main class="relative z-20">
      <Navbar />
      <!-- Content Sections Below Video -->
      <div>
        <!-- Hero CTA Section -->
        <div class="min-h-screen flex items-center justify-center px-4 md:px-10 py-10">
          <div class="max-w-4xl w-full -translate-y-8 text-center space-y-8 md:-translate-y-12">
            <div class="space-y-4">
              <h2 class="text-4xl md:text-6xl font-serif">Because Your Safety Matters</h2>
              <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto">
                Ever been in a situation where you felt threatened or scared with no
                way out? We're here to change that for you and everyone you care
                about. No more suffering alone, no more dead ends. It's time to feel
                safe. ✨
              </p>
            </div>
            <WaitlistButton
              className="bg-black text-white py-3 px-6 text-base rounded-[24px] hover:shadow-[0_8px_30px_rgba(0,0,0,0.5)] transition-shadow duration-300 cursor-pointer font-semibold inline-block"
              client:load
            >
              Make the world safer
            </WaitlistButton>
          </div>
        </div>

        <!-- Mission Section -->
        <section id="mission" class="min-h-[100svh] flex items-center justify-center px-4 md:px-10 py-20 backdrop-blur-[2px]" style="background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.42) 14%, rgba(0,0,0,0.42) 86%, rgba(0,0,0,0) 100%);">
          <div class="space-y-6 md:space-y-10 max-w-2xl">
            <h2 class="text-4xl md:text-6xl font-serif">Our Mission</h2>
            <p class="font-satoshi text-base md:text-lg leading-relaxed text-white/85">
              We believe safety should not be a luxury or something you have to
              worry about when you are just trying to live your life.
            </p>
            <p class="font-satoshi text-base md:text-lg leading-relaxed text-white/85">
              Our mission is simple: give people the tools they need to feel
              secure and get help fast when it matters most. Whether someone is
              walking home alone, in an unsafe relationship, or facing any threat
              to their wellbeing, they deserve more than just hoping for the best.
            </p>
            <p class="font-satoshi text-base md:text-lg leading-relaxed text-white/85">
              We are building Halo to bridge that gap between feeling vulnerable
              and feeling protected. Real safety features that work when you need
              them, designed by people who understand what it is like to feel unsafe.
            </p>
            <p class="font-satoshi text-base md:text-lg leading-relaxed text-white/85">
              Everyone should be able to move through the world with confidence,
              knowing that help is always within reach.
            </p>
          </div>
        </section>

        <!-- About Section -->
        <section id="about" class="min-h-[100svh] flex items-center justify-center px-4 md:px-10 py-20" style="background: transparent;">
          <div class="space-y-6 md:space-y-10 max-w-2xl">
            <h2 class="text-4xl md:text-6xl font-serif">About Us</h2>
            <p class="font-satoshi text-base md:text-lg leading-relaxed text-white/85">
              We are Ananjan and Ritankar, two friends who decided we could not just
              stand by while people we care about face real safety threats every day.
            </p>
            <p class="font-satoshi text-base md:text-lg leading-relaxed text-white/85">
              After hearing too many stories from friends and family about feeling
              unsafe walking alone or being in dangerous situations without help,
              we realized the tools out there were missing what people need in
              critical moments.
            </p>
            <p class="font-satoshi text-base md:text-lg leading-relaxed text-white/85">
              We are building Halo because everyone deserves to feel safe and have
              real help when they need it.
            </p>
          </div>
        </section>
      </div>
      <Footer />
    </main>
  </body>
</html>
